    given-names: Jack Patrick
    affiliation: "School of Biological Sciences, Queen's University Belfast"
    orcid: "https://orcid.org/0009-0008-5810-6779"
license: MIT
repository-code: "https://github.com/jackburton-qub/GRACE"
version: "1.0.0"
date-released: "2026-01-06"
keywords:
  - microsatellite
  - SSR
  - primer design
  - BLAST
  - population genetics
  - bioinformatics
